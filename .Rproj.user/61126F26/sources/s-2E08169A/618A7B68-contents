for file_name in multimodel:
        tm = xr.open_mfdataset(file_name,chunks='auto',decode_times=True)
        #calculate
        #t_mean= tm.sel(time=slice('1981-01-01', '2010-12-31')).groupby('time.season').mean('time')
        #t_mean = tm.loc[dict(time=slice('1981', '2010'))].groupby('time.season').mean('time')
        
        t_mean = tm.where((tm['time.year'] > 1949) & (tm['time.year'] < 1952) , drop=True).groupby(
            'time.month').mean('time')
        
        #t_std = tm.sel(time=slice('1981-01-01', '2010-12-31')).groupby('time.season').std('time')
        #t_std = tm.loc[dict(time=slice('1981', '2010'))].groupby('time.season').std('time')
        #append
        t_mean_monthly.append(t_mean)
        #t_std_monthly.append(t_std)

t_mean_monthly = xr.concat(t_mean_monthly,pd.Index(range(3),name='model')).rename({"tasmax": "t_mean"})
